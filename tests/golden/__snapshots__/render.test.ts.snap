// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`buildDashboardHtml > renders a stable, well-formed document 1`] = `
"<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Morning Briefing — Monday, June 29, 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,400;0,500;0,600;0,700;1,400&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{--bg:#ffffff;--surface:#fff;--ink:#15171b;--muted:#565b64;--border:rgba(18,22,28,0.12);--accent:#00497f;
--urgent:#dc2626;--high:#bd7f0e;--tracking:#8b909a;--sig-strong:#0e8a4f;--sig-light:#bd7f0e;--sig-none:#bcc1c9;}
*{box-sizing:border-box}
body{margin:0;background:var(--bg);color:var(--ink);font-family:Spectral,Georgia,serif;line-height:1.55}
a{color:var(--accent)}
.wrap{max-width:840px;margin:0 auto;padding:28px 20px 80px}
.masthead{border-bottom:2px solid var(--ink);padding-bottom:14px;margin-bottom:18px}
.masthead h1{font-family:Spectral,Georgia,serif;font-size:34px;margin:0 0 4px}
.masthead .date{color:var(--muted);font-size:14px}
.stats{display:flex;gap:18px;margin-top:10px;font-size:13px;color:var(--muted)}
.stats b{color:var(--ink)}
.tabs{display:flex;flex-wrap:wrap;gap:6px;margin:18px 0 22px;position:sticky;top:0;background:var(--bg);padding:8px 0;z-index:5}
.tab{border:1px solid var(--border);background:var(--surface);color:var(--muted);padding:7px 13px;border-radius:999px;
font-size:13px;font-weight:600;cursor:pointer}
.tab.active{background:var(--ink);color:#fff;border-color:var(--ink)}
.panel{display:none}
.panel.active{display:block}
h3{font-family:Spectral,Georgia,serif;font-size:20px;margin:4px 0}
.hint{color:var(--muted);font-style:italic}
/* cards */
.story,.pattern{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:16px 18px;margin-bottom:12px;cursor:pointer}
.card-top{display:flex;gap:12px;align-items:flex-start}
.story-dot{width:10px;height:10px;border-radius:50%;margin-top:7px;flex:none}
.dot-urgent{background:var(--urgent)}.dot-high{background:var(--high)}.dot-tracking{background:var(--tracking)}
.story-content{flex:1}
.story-meta{display:flex;gap:10px;align-items:center;margin-bottom:4px}
.priority-tag{font-size:11px;font-weight:700;padding:2px 7px;border-radius:5px;color:#fff;letter-spacing:.04em}
.tag-urgent{background:var(--urgent)}.tag-high{background:var(--high)}.tag-tracking{background:var(--tracking)}
.sector-label{font-size:12px;color:var(--muted)}
.one-liner{color:var(--muted);font-size:14px}
.chevron{color:var(--muted);transition:transform .2s}
.open .chevron{transform:rotate(180deg)}
.card-detail{max-height:0;overflow:hidden;transition:max-height .25s ease}
.open .card-detail{max-height:4000px}
.card-detail-inner{padding-top:12px}
.card-detail-inner p{margin:0 0 10px}
/* sources */
.story-sources,.deep-dive-sources{margin-top:12px;font-size:13px}
.sources-label{font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.06em;margin-right:8px}
.source-sep{margin:0 7px;color:var(--border)}
/* sectors */
.sector-item{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:12px 14px;margin-bottom:8px}
.sector-top{display:flex;gap:9px;align-items:center}
.sector-dot{width:9px;height:9px;border-radius:50%}
.sector-dot.active{background:var(--sig-strong)}.sector-dot.quiet{background:var(--sig-none)}
.sector-name{font-weight:600}
.sector-summary{color:var(--muted);font-size:14px;margin-top:6px;padding-left:18px}
/* week */
.week-item{display:flex;gap:12px;align-items:center;padding:10px 0;border-bottom:1px solid var(--border)}
.week-item.critical{font-weight:600}
.week-day{font-family:"IBM Plex Mono",monospace;font-size:13px;width:54px;flex:none;color:var(--muted)}
.week-event{flex:1}
.week-tag{font-size:11px;padding:2px 8px;border-radius:5px;text-transform:capitalize}
/* patterns */
.pattern{background:#211e17;color:#f2ede2;border-color:#33302a}
.pattern h3{color:#fff}
.pattern-label{font-size:11px;letter-spacing:.08em;color:#d9b160;font-weight:700}
.subtitle{color:#b8b3aa;font-size:14px;margin:2px 0 6px}
.pattern-cat{display:inline-block;font-size:11px;background:#33302a;color:#d8d2c6;padding:2px 8px;border-radius:5px;margin-right:6px}
/* deep dive */
.deep-dive{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:24px}
.deep-dive-kicker{font-size:12px;font-weight:700;letter-spacing:.06em;color:var(--accent);display:flex;align-items:center;gap:7px}
.deep-dive-kicker-dot{width:8px;height:8px;border-radius:50%;background:var(--accent)}
.deep-dive h2{font-family:Spectral,Georgia,serif;font-size:28px;margin:10px 0 6px}
.standfirst{font-size:17px;color:var(--muted);margin-bottom:14px}
.deep-dive-why{font-size:13px;color:var(--accent);margin-bottom:14px}
.deep-dive .body p{margin:0 0 12px}
/* signal */
.sig-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px 16px;margin-bottom:10px}
.sig-card.sig-quiet{opacity:.6}
.sig-header{display:flex;justify-content:space-between;align-items:center}
.sig-left{display:flex;gap:9px;align-items:center}
.sig-dot{width:9px;height:9px;border-radius:50%}
.sig-strong{background:var(--sig-strong)}.sig-light{background:var(--sig-light)}.sig-none{background:var(--sig-none)}
.sig-name{font-weight:600}
.sig-handle{color:var(--muted);font-size:13px;margin-left:7px}
.sig-source-badge{font-size:10px;font-weight:700;color:var(--muted);border:1px solid var(--border);padding:2px 6px;border-radius:5px}
.sig-title{display:block;margin-top:8px;font-weight:600}
.sig-summary{color:var(--muted);font-size:14px;margin-top:5px}
.sig-connection{color:var(--accent);font-size:13px;margin-top:6px}
.sig-quiet-section{margin-top:16px}
.sig-quiet-label{font-size:11px;font-weight:700;letter-spacing:.06em;color:var(--muted);margin-bottom:8px}
</style>
</head>
<body>
<div class="wrap">
  <header class="masthead">
    <h1>Morning Briefing</h1>
    <div class="date">Monday, June 29, 2026</div>
    <div class="stats">
      <span><b>1</b> urgent</span>
      <span><b>10</b>/11 sectors active</span>
    </div>
  </header>
  <nav class="tabs"><button class="tab active" data-tab="top-stories" onclick="showTab('top-stories')">Top Stories</button><button class="tab" data-tab="sector-scan" onclick="showTab('sector-scan')">Sector Scan</button><button class="tab" data-tab="week-ahead" onclick="showTab('week-ahead')">Week Ahead</button><button class="tab" data-tab="pattern-watch" onclick="showTab('pattern-watch')">Pattern Watch</button><button class="tab" data-tab="deep-dive" onclick="showTab('deep-dive')">Deep Dive</button><button class="tab" data-tab="signal-scan" onclick="showTab('signal-scan')">Signal Scan</button></nav>
  <section class="panel active" id="top-stories">
    <div class="story" data-priority="urgent" onclick="toggleCard(this)">
      <div class="card-top">
        <div class="story-dot dot-urgent"></div>
        <div class="story-content">
          <div class="story-meta">
            <span class="priority-tag tag-urgent">URGENT</span>
            <span class="sector-label">Geopolitics</span>
          </div>
          <h3>US-Iran MOU Holds — But Switzerland Talks Already Hitting Turbulence</h3>
          <div class="one-liner">Trump and Iran&#39;s president signed a 60-day ceasefire MOU on June 17, but the first technical talks in Switzerland stalled almost immediately, leaving the fragile peace in question as this week opens.</div>
        </div>
        <div class="chevron">▾</div>
      </div>
      <div class="card-detail">
        <div class="card-detail-inner"><p>On June 17, 2026, US President Trump and Iranian President signed a memorandum of understanding to end the 2026 Iran war — a conflict initiated by the joint US-Israeli &#39;Operation Epic Fury&#39; strikes on February 28. The MOU established a 60-day ceasefire extension, called for reopening the Strait of Hormuz to commercial shipping toll-free, lifted the US naval blockade of Iranian ports, and set the stage for negotiations on a permanent nuclear agreement. However, the MOU notably excludes Iran&#39;s ballistic missile program and its network of regional proxies, two of the most contentious issues.</p>
<p>The new deal almost immediately ran into turbulence. According to AP, technical talks scheduled in Switzerland on June 18 were postponed. Trump issued threats that further complicated the atmosphere, while also denying a reported $300 billion government fund to Iran as &#39;fake news.&#39; Trump defended the MOU at the G7 in France by arguing that a prolonged war could have caused an &#39;economic catastrophe.&#39; Iran&#39;s Supreme National Security Council warned that ceasefire violations would not be tolerated and that Iranian forces would &#39;soon respond&#39; to any provocations.</p>
<p>Israel remains a critical wild card. Netanyahu publicly stated that &#39;we still have goals to complete,&#39; including securing enriched nuclear material within Iran — which Israel&#39;s Foreign Minister called a &#39;precondition&#39; to end the conflict. The IAEA still has not been able to resume inspections of Iran&#39;s nuclear program since the June 2025 Twelve-Day War. On June 19, Israel and Hezbollah agreed to halt fighting, per AP, though Lebanon&#39;s status relative to any broader deal remains disputed.</p>
<p>The economic consequences of the war have been severe. Iran&#39;s blockade of the Strait of Hormuz — one of the world&#39;s most vital oil chokepoints — triggered fuel shortages across Asia and rippling disruptions globally. Markets responded dramatically to signs of de-escalation: the Dow hit an all-time high and oil dropped roughly 33% after the peace deal appeared imminent. The next 60-day window is now the most critical diplomatic period in the Middle East in years, and Congress is already asking whether the war was &#39;worth it,&#39; per AP reporting.</p><div class="story-sources"><span class="sources-label">SOURCES</span><div class="sources-list"><a class="source-link" href="https://en.wikipedia.org/wiki/2026_Iran_war_ceasefire" target="_blank" rel="noopener">Wikipedia – 2026 Iran War Ceasefire</a><span class="source-sep">·</span><a class="source-link" href="https://www.britannica.com/event/2026-Iran-war" target="_blank" rel="noopener">Britannica – 2026 Iran War</a><span class="source-sep">·</span><a class="source-link" href="https://en.wikipedia.org/wiki/2025%E2%80%932026_Iran%E2%80%93United_States_negotiations" target="_blank" rel="noopener">Wikipedia – 2025-2026 Iran-US Negotiations</a><span class="source-sep">·</span><a class="source-link" href="https://commonslibrary.parliament.uk/research-briefings/cbp-10637/" target="_blank" rel="noopener">House of Commons Library</a></div></div></div>
      </div>
    </div>
    <div class="story" data-priority="high" onclick="toggleCard(this)">
      <div class="card-top">
        <div class="story-dot dot-high"></div>
        <div class="story-content">
          <div class="story-meta">
            <span class="priority-tag tag-high">HIGH</span>
            <span class="sector-label">Markets</span>
          </div>
          <h3>Fed Chair Warsh&#39;s Hawkish Debut Rocks Markets and Crypto</h3>
          <div class="one-liner">In his first FOMC meeting, new Fed Chair Kevin Warsh held rates at 3.5%-3.75% but signaled possible hikes, rattling equities and sending Bitcoin through key support levels.</div>
        </div>
        <div class="chevron">▾</div>
      </div>
      <div class="card-detail">
        <div class="card-detail-inner"><p>Kevin Warsh, Trump&#39;s pick to succeed Jerome Powell, chaired his first FOMC meeting on June 17 and delivered a decidedly hawkish signal. The Fed held rates unanimously at 3.50%-3.75%, but the updated dot plot — the Fed&#39;s forecast of future rates — shocked markets: the median projection now puts the year-end federal funds rate at 3.8%, up from 3.4% in March, with nine of 18 officials penciling in at least one rate hike in 2026. Warsh withheld his own dot-plot estimate, becoming the first Fed chair in over a decade to do so, and abandoned the extensive forward guidance that Powell favored — adding a layer of uncertainty investors found deeply unsettling.</p>
<p>Markets moved swiftly. Bitcoin fell through the key $63,000 support level, with market maker Wintermute warning that a slide into the $50s &#39;is not ruled out.&#39; The Nasdaq and S&amp;P 500 each fell over 1% on the day. CME FedWatch data put the odds of a rate hike as early as October at roughly 60%. The two-year Treasury yield surged 14 basis points. Five AI-oriented stocks, which had been responsible for roughly half of the S&amp;P 500&#39;s year-to-date return, joined the broader selloff.</p>
<p>Just days after Warsh&#39;s meeting, the Fed proposed new stablecoin KYC rulemaking under the GENIUS Act — a joint effort with Treasury and the FDIC. All Fed governors voted in favor except Warsh himself, who abstained without explanation, raising immediate questions about how the new chair intends to exercise influence across the financial regulatory stack.</p>
<p>The macro backdrop is now sharply different from expectations entering June. The peace deal with Iran had eased oil prices and inflation fears, but a Fed now leaning toward hikes has replaced cut bets that crypto and growth equities had been pricing in. Rabobank and other forecasters had predicted Warsh would pivot dovish; that thesis is now firmly off the table. Watch July FOMC odds and Q2 CPI data as the next key catalysts.</p><div class="story-sources"><span class="sources-label">SOURCES</span><div class="sources-list"><a class="source-link" href="https://www.banklesstimes.com/articles/2026/06/21/crypto-market-recap-tether-kills-ausdt-mstr-could-sink-below-100-cme-sues-over-crypto-futures-classification-and-more-june-15-20-2026/" target="_blank" rel="noopener">BanklessTimes – Crypto Recap June 15-20</a><span class="source-sep">·</span><a class="source-link" href="https://www.coindesk.com/tech/2026/06/18/live-markets-bitcoin-and-ether-etfs-lost-usd111-million-combined-as-rate-cut-hopes-died" target="_blank" rel="noopener">CoinDesk – Bitcoin &amp; Ether ETF Outflows</a><span class="source-sep">·</span><a class="source-link" href="https://finance.yahoo.com/markets/crypto/articles/bitcoin-price-falls-below-key-121215163.html" target="_blank" rel="noopener">Yahoo Finance – Bitcoin Falls Below $63K</a><span class="source-sep">·</span><a class="source-link" href="https://finance.yahoo.com/markets/crypto/articles/jerome-powell-supports-feds-stablecoin-153327407.html" target="_blank" rel="noopener">Yahoo Finance – Powell Supports Stablecoin Rules, Warsh Abstains</a></div></div></div>
      </div>
    </div>
    <div class="story" data-priority="high" onclick="toggleCard(this)">
      <div class="card-top">
        <div class="story-dot dot-high"></div>
        <div class="story-content">
          <div class="story-meta">
            <span class="priority-tag tag-high">HIGH</span>
            <span class="sector-label">Applied Tech &amp; Industry</span>
          </div>
          <h3>Anthropic Hits $965B Valuation, Files Confidentially for IPO</h3>
          <div class="one-liner">Anthropic&#39;s $65B Series H round eclipsed OpenAI&#39;s valuation for the first time and was quickly followed by a confidential IPO filing, igniting the most consequential tech public market race in years.</div>
        </div>
        <div class="chevron">▾</div>
      </div>
      <div class="card-detail">
        <div class="card-detail-inner"><p>On May 28, Anthropic closed a $65 billion Series H round at a $965 billion post-money valuation, surpassing rival OpenAI&#39;s $852 billion valuation for the first time. The round was co-led by Altimeter Capital, Dragoneer, Greenoaks, and Sequoia Capital, with broad participation from institutional investors including Baillie Gifford, Blackstone, Brookfield, DST Global, Fidelity, and Temasek. Strategic infrastructure partners — Samsung, SK Hynix, and Micron — also joined, reflecting Anthropic&#39;s compute scaling ambitions. The round includes $15 billion in previously committed hyperscaler investments, including $5 billion from Amazon.</p>
<p>The valuation almost triples Anthropic&#39;s February 2026 figure of $380 billion. Revenue growth has been explosive: the company reported a $47 billion annualized run rate, up from $30 billion earlier in 2026 and just $10 billion in full-year 2025. Claude Code — the AI coding assistant — has been the primary driver, with the Wall Street Journal reporting that Anthropic expects a 130% revenue surge that would bring it to its first operating profit. Claude Opus 4.8, released alongside the funding announcement, leads agentic coding benchmarks.</p>
<p>By June 1, Anthropic had confidentially filed IPO paperwork with the SEC, potentially leapfrogging OpenAI in the race to public markets. OpenAI, valued at $852 billion after its $122 billion March round, is also preparing its own confidential IPO filing. SpaceX/xAI is targeting a $2 trillion valuation in its pending IPO. The AI IPO window, if it opens, would represent the most significant cluster of tech listings since the early 2000s.</p>
<p>Anthropics faces one notable headwind: a legal dispute with the Pentagon, which designated it a &#39;supply chain risk&#39; over its refusal to allow unrestricted military access to its tools. The company is also reportedly planning to more widely deploy models on par with its cybersecurity-focused Mythos model — a move that will directly intersect with Trump&#39;s June 2 AI executive order requiring voluntary pre-release government review of frontier models.</p><div class="story-sources"><span class="sources-label">SOURCES</span><div class="sources-list"><a class="source-link" href="https://www.anthropic.com/news/series-h" target="_blank" rel="noopener">Anthropic – Series H Announcement</a><span class="source-sep">·</span><a class="source-link" href="https://techcrunch.com/2026/05/28/anthropic-raises-65-billion-nears-1t-valuation-ahead-of-ipo/" target="_blank" rel="noopener">TechCrunch – Anthropic Raises $65B</a><span class="source-sep">·</span><a class="source-link" href="https://www.cnbc.com/2026/05/28/anthropic-open-ai-startup-value.html" target="_blank" rel="noopener">CNBC – Anthropic Tops OpenAI</a><span class="source-sep">·</span><a class="source-link" href="https://fortune.com/2026/06/01/anthropic-confidentially-files-ipo-965-billion-valuation/" target="_blank" rel="noopener">Fortune – Anthropic Confidential IPO Filing</a></div></div></div>
      </div>
    </div>
    <div class="story" data-priority="high" onclick="toggleCard(this)">
      <div class="card-top">
        <div class="story-dot dot-high"></div>
        <div class="story-content">
          <div class="story-meta">
            <span class="priority-tag tag-high">HIGH</span>
            <span class="sector-label">AI Regulation &amp; Governance</span>
          </div>
          <h3>Colorado AI Act Gutted and Reset to Jan 2027 — State AI Regulation in Full Retreat</h3>
          <div class="one-liner">Colorado Governor Polis signed a bill in May that substantially scaled back the nation&#39;s first comprehensive AI law and pushed its effective date to January 2027, as federal preemption pressure mounts from Washington.</div>
        </div>
        <div class="chevron">▾</div>
      </div>
      <div class="card-detail">
        <div class="card-detail-inner"><p>On May 14, 2026, Colorado Governor Jared Polis signed SB 189, a significant revision to the landmark 2024 Colorado AI Act (SB 24-205). The amendment delays the effective date from June 30, 2026 to January 1, 2027, and substantially scales back its original requirements. The revised law eliminates the risk-based framework&#39;s &#39;duty of care&#39; against algorithmic discrimination, scraps mandatory risk management programs and impact assessments for deployers, and drops certain reporting obligations to the Colorado AG. What remains is a narrower transparency and disclosure regime focused on automated decision-making technologies.</p>
<p>The gutting of the Colorado AI Act is a significant bellwether for the entire US state AI regulation landscape. The law was intended to be the nation&#39;s first comprehensive AI regulatory framework — covering employment, housing, healthcare, education, and credit decisions. It faced relentless industry opposition and a federal headwind from the Trump administration, which in December 2025 created an AI Litigation Task Force to challenge state laws deemed to conflict with federal AI policy, and explicitly targeted the Colorado act in executive orders.</p>
<p>The White House&#39;s March 2026 National Policy Framework for AI urged Congress to preempt state AI laws, calling them an &#39;inherently interstate phenomenon.&#39; This dynamic is now reshaping the regulatory landscape: as Colorado retreats, California&#39;s Transparency in Frontier AI Act and New York&#39;s RAISE Act remain on the books but face similar pressure. The EU AI Act transparency rules, by contrast, are marching toward their August 2026 compliance deadline — creating an increasingly asymmetric regulatory environment where European enterprises face hard obligations while US companies navigate a patchwork in retreat.</p>
<p>For enterprises, the Colorado SB 189 signing offers short-term relief, but the January 2027 date and ongoing federal-state tension mean compliance uncertainty is far from resolved. Cooley and other law firms advising clients note that businesses should &#39;continue to closely monitor both state and federal legislative developments.&#39;</p><div class="story-sources"><span class="sources-label">SOURCES</span><div class="sources-list"><a class="source-link" href="https://www.hunton.com/privacy-and-cybersecurity-law-blog/colorado-ai-act-amended-and-effective-date-delayed" target="_blank" rel="noopener">Hunton – Colorado AI Act Amended</a><span class="source-sep">·</span><a class="source-link" href="https://www.cooley.com/news/insight/2026/2026-04-24-state-ai-laws-where-are-they-now" target="_blank" rel="noopener">Cooley – State AI Laws Update</a><span class="source-sep">·</span><a class="source-link" href="https://www.skadden.com/insights/publications/2026/06/new-ai-executive-order" target="_blank" rel="noopener">Skadden – Trump AI Executive Order</a><span class="source-sep">·</span><a class="source-link" href="https://www.whitehouse.gov/releases/2026/03/president-donald-j-trump-unveils-national-ai-legislative-framework/" target="_blank" rel="noopener">White House – AI National Policy Framework</a></div></div></div>
      </div>
    </div>
    <div class="story" data-priority="tracking" onclick="toggleCard(this)">
      <div class="card-top">
        <div class="story-dot dot-tracking"></div>
        <div class="story-content">
          <div class="story-meta">
            <span class="priority-tag tag-tracking">TRACKING</span>
            <span class="sector-label">Frontier Tech / AI</span>
          </div>
          <h3>EU Picks EUROPA Consortium for Sovereign Open-Source Frontier AI Model</h3>
          <div class="one-liner">The European Commission selected the Domyn-led EUROPA consortium to build a 400B+ parameter open-source model across all 24 EU languages, backed by a dedicated Nvidia Blackwell cluster and EuroHPC compute.</div>
        </div>
        <div class="chevron">▾</div>
      </div>
      <div class="card-detail">
        <div class="card-detail-inner"><p>On June 19, the European Commission announced it had selected the EUROPA consortium, led by Italian company Domyn, as the winner of its Frontier AI Grand Challenge. The consortium is tasked with building a sovereign, open-source AI model exceeding 400 billion parameters — making it comparable in scale to the world&#39;s most capable frontier systems. The model will be trained natively across all 24 official EU languages, enabling European public institutions, universities, and hospitals to access frontier-grade AI without routing sensitive data through non-EU cloud infrastructure.</p>
<p>The project is backed by a dedicated 6,000-chip Nvidia Blackwell cluster and access to up to 2.5% of EuroHPC&#39;s high-performance supercomputing capacity. It sits within the broader European Technological Sovereignty Package announced June 3, which includes a proposed Cloud and AI Development Act (CADA) with four &#39;Union assurance levels&#39; for cloud sovereignty, and a Chips Act 2.0 aimed at building European semiconductor capacity.</p>
<p>The EUROPA selection comes as the EU AI Act&#39;s transparency provisions approach their August 2026 compliance deadline — putting European enterprise AI governance on a very different trajectory than the US, where voluntary frameworks and state law retreats dominate. In May 2026, the European Parliament also reached political agreement to simplify AI Act rules via an &#39;AI omnibus,&#39; streamlining compliance for smaller companies.</p>
<p>The context is stark: private AI investment in the US runs approximately 24 times higher than in Europe. The EUROPA project and the broader sovereignty stack — including Mistral AI&#39;s €830 million institutional debt raise to build a major Paris-area data center — represent the EU&#39;s most concerted effort yet to close that gap on its own terms.</p><div class="story-sources"><span class="sources-label">SOURCES</span><div class="sources-list"><a class="source-link" href="https://commission.europa.eu/news-and-media/news/strengthening-europes-tech-sovereignty-2026-06-03_en" target="_blank" rel="noopener">European Commission – Tech Sovereignty Package</a><span class="source-sep">·</span><a class="source-link" href="https://digital-strategy.ec.europa.eu/en/policies/european-approach-artificial-intelligence" target="_blank" rel="noopener">EU Digital Strategy – EUROPA Consortium Selection</a><span class="source-sep">·</span><a class="source-link" href="https://ieu-monitoring.com/editorial/eu-commission-picks-europa-consortium-led-by-domyn-to-build-open-frontier-ai-model/1243623" target="_blank" rel="noopener">Insight EU – EUROPA Consortium</a><span class="source-sep">·</span><a class="source-link" href="https://digital-strategy.ec.europa.eu/en/policies/regulatory-framework-ai" target="_blank" rel="noopener">EU AI Act Page</a></div></div></div>
      </div>
    </div></section>
<section class="panel" id="sector-scan">
    <div class="sector-item">
      <div class="sector-top">
        <div class="sector-dot active"></div>
        <span class="sector-name">Frontier Tech / AI</span>
      </div>
      <div class="sector-summary">The EU selected the EUROPA consortium to build a 400B+ parameter open-source sovereign AI model across all 24 EU languages, backed by EuroHPC compute and a dedicated Nvidia Blackwell cluster. Separately, Google DeepMind&#39;s Gemini 3.5 Pro (2M context window, &#39;Deep Think&#39; mode) and Apple&#39;s rebuilt Siri AI (launched June 8) continue to reshape the competitive frontier. xAI is training Grok 5 on expanded 1.5GW Colossus 2 infrastructure, with a late-summer release projected.</div>
    </div>
    <div class="sector-item">
      <div class="sector-top">
        <div class="sector-dot active"></div>
        <span class="sector-name">Applied Tech &amp; Industry</span>
      </div>
      <div class="sector-summary">Anthropic&#39;s $65B Series H at a $965B valuation eclipsed OpenAI for the first time, followed immediately by a confidential IPO filing — igniting a race to public markets alongside OpenAI and SpaceX/xAI. Anthropic&#39;s $47B annualized run rate, powered by Claude Code enterprise adoption, marks an 80-fold revenue increase. GitHub Copilot&#39;s switch to per-token &#39;AI Credits&#39; billing is generating significant backlash from power users reporting 10x-50x cost increases.</div>
    </div>
    <div class="sector-item">
      <div class="sector-top">
        <div class="sector-dot active"></div>
        <span class="sector-name">US Policy &amp; Power</span>
      </div>
      <div class="sector-summary">Trump&#39;s June 2 AI executive order created a voluntary 30-day pre-release review framework for frontier models, with NSA leading a classified benchmarking process to designate &#39;covered frontier models.&#39; The August 1 deadline for agency deliverables is now eight weeks away. The Department of War has signed AI access agreements with OpenAI, Google, Amazon, Microsoft, NVIDIA, Oracle, SpaceX, and Reflection to bring AI to classified networks.</div>
    </div>
    <div class="sector-item">
      <div class="sector-top">
        <div class="sector-dot active"></div>
        <span class="sector-name">AI Regulation &amp; Governance</span>
      </div>
      <div class="sector-summary">Colorado gutted and delayed its landmark AI Act to January 2027, largely stripping its risk-management and anti-discrimination provisions under federal and industry pressure. The EU AI Act&#39;s transparency rules take effect in August 2026, creating a sharp transatlantic regulatory divergence. The White House continues to push for federal preemption of state AI laws, with its National Policy Framework urging Congress to act.</div>
    </div>
    <div class="sector-item">
      <div class="sector-top">
        <div class="sector-dot active"></div>
        <span class="sector-name">Geopolitics</span>
      </div>
      <div class="sector-summary">The US-Iran MOU signed June 17 established a 60-day ceasefire and framework for nuclear talks, but Switzerland technical talks stalled almost immediately. Israel and Hezbollah agreed to halt fighting on June 19 per AP, but Lebanon&#39;s status under any final deal remains contested. The Strait of Hormuz is nominally reopened toll-free for the ceasefire period, with Trump warning tolls could be imposed if peace talks fail.</div>
    </div>
    <div class="sector-item">
      <div class="sector-top">
        <div class="sector-dot active"></div>
        <span class="sector-name">China</span>
      </div>
      <div class="sector-summary">Beijing is deepening its double-down on technological self-sufficiency across rare earths, batteries, AI, and robotics, according to Rabobank&#39;s analysis. McKinsey data show the 2025 tariff regime pushed over $165 billion in trade away from the US-China corridor. EU-China tensions are widening beyond EVs to wind, solar, and mature-node semiconductors, per Lazard&#39;s geopolitical outlook.</div>
    </div>
    <div class="sector-item">
      <div class="sector-top">
        <div class="sector-dot active"></div>
        <span class="sector-name">Markets</span>
      </div>
      <div class="sector-summary">Fed Chair Warsh&#39;s first FOMC meeting held rates at 3.50%-3.75% but the dot plot surprised hawkishly, with the median now projecting 3.8% year-end and 9 of 18 officials penciling in a hike. CME FedWatch puts October hike odds near 60%. The 10-year Treasury yield hit 4.46%, the 2-year 4.14%. Goldman Sachs cut its 2026 gold target to $4,900 from $5,400 on fading rate-cut odds. Five AI stocks remain responsible for roughly half the S&amp;P 500&#39;s year-to-date return.</div>
    </div>
    <div class="sector-item">
      <div class="sector-top">
        <div class="sector-dot active"></div>
        <span class="sector-name">Digital Finance</span>
      </div>
      <div class="sector-summary">The Federal Reserve proposed GENIUS Act stablecoin KYC rulemaking jointly with Treasury and FDIC — all governors voted yes except new Chair Warsh, who abstained without explanation. Bitcoin fell through $63,000 support following the hawkish FOMC, with Wintermute warning of a possible slide into the $50s. Tokenized real-world assets grew ~589% from early 2025 to June 2026, with public equities tokenization expanding 422%. Tether shut down its gold-backed aUSDT stablecoin, redirecting to Tether Gold.</div>
    </div>
    <div class="sector-item">
      <div class="sector-top">
        <div class="sector-dot active"></div>
        <span class="sector-name">Energy</span>
      </div>
      <div class="sector-summary">Oil dropped roughly 33% as the US-Iran MOU signaled Strait of Hormuz reopening, though the ceasefire&#39;s fragility keeps energy markets on edge. Trump announced no Hormuz tolls during the 60-day ceasefire window but reserved the right to implement them if peace talks fail. The EU&#39;s tech sovereignty package includes a strategic roadmap for digitalizing the energy sector and integrating AI into power grid management.</div>
    </div>
    <div class="sector-item">
      <div class="sector-top">
        <div class="sector-dot active"></div>
        <span class="sector-name">Defense &amp; Security</span>
      </div>
      <div class="sector-summary">Anthropic&#39;s Project Glasswing reported Claude Mythos Preview found over 10,000 high/critical severity vulnerabilities in a single month, a capability that drove Trump&#39;s June 2 frontier AI executive order. The Department of War signed AI access agreements with eight major tech firms for classified network deployment. Iran&#39;s IRGC-linked crypto platforms Wallex, Bitpin, and Ramzinex were sanctioned by Treasury&#39;s OFAC for processing transactions for the Revolutionary Guard.</div>
    </div>
    <div class="sector-item">
      <div class="sector-top">
        <div class="sector-dot quiet"></div>
        <span class="sector-name">Labor &amp; Workforce</span>
      </div>
      
    </div></section>
